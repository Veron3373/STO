# ═══════════════════════════════════════════════════════════════════════════════
# 🔧 ЄДИНИЙ ФАЙЛ КОНФІГУРАЦІЇ ПРОЕКТУ (.env.example)
# ═══════════════════════════════════════════════════════════════════════════════
#
# 📌 ІНСТРУКЦІЯ:
# 1. Скопіюй цей файл як .env:  copy .env.example .env
# 2. Заповни всі значення своїми даними
# 3. НІКОЛИ не коміть .env в Git!
# 4. Після заповнення — все підтягнеться автоматично
#    (project.config.ts, deploy-скрипти, vite.config.ts)
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SUPABASE
# ═══════════════════════════════════════════════════════════════════════════════
# Знайти в: https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_key_here

# ═══════════════════════════════════════════════════════════════════════════════
# 🔑 GOOGLE OAUTH
# ═══════════════════════════════════════════════════════════════════════════════
# Знайти в: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ═══════════════════════════════════════════════════════════════════════════════
# 🌐 VERCEL
# ═══════════════════════════════════════════════════════════════════════════════
# Домен вашого Vercel-проекту (без https://)
VITE_VERCEL_DOMAIN=your-project.vercel.app

# ═══════════════════════════════════════════════════════════════════════════════
# 🐙 GITHUB
# ═══════════════════════════════════════════════════════════════════════════════
# Ваш GitHub username та назва репозиторію
VITE_GITHUB_USERNAME=your_github_username
VITE_GITHUB_REPO=STO

# ═══════════════════════════════════════════════════════════════════════════════
# 👤 GIT (для deploy-скриптів)
# ═══════════════════════════════════════════════════════════════════════════════
# Ім'я та email для Git-комітів
VITE_GIT_USER_NAME=YourName
VITE_GIT_USER_EMAIL=your@email.com

# ═══════════════════════════════════════════════════════════════════════════════
# 📦 ПРОЕКТ
# ═══════════════════════════════════════════════════════════════════════════════
# Назва проекту (для vercel.json, package.json)
VITE_PROJECT_NAME=your-project-name

# ═══════════════════════════════════════════════════════════════════════════════
# 📱 TELEGRAM BOT (зберігається в Supabase Secrets, НЕ тут!)
# ═══════════════════════════════════════════════════════════════════════════════
# Встановити: Supabase → Edge Functions → Secrets → TELEGRAM_BOT_TOKEN
# TELEGRAM_BOT_TOKEN=123456789:AAF... (тільки для довідки)

# ═══════════════════════════════════════════════════════════════════════════════
# 📱 SMS CLUB (опціонально, зберігається в Supabase Secrets)
# ═══════════════════════════════════════════════════════════════════════════════
# SMSCLUB_TOKEN=your_smsclub_api_token
# SMSCLUB_SENDER=YourSenderName
