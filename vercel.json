{
  "version": 2,
  "name": "sto",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 8 * * 1,4"
    }
  ],
  "rewrites": [
    {
      "source": "/bukhhalteriya",
      "destination": "/bukhhalteriya.html"
    },
    {
      "source": "/planyvannya",
      "destination": "/planyvannya.html"
    },
    {
      "source": "/main",
      "destination": "/main.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
